@{
    ViewData["Title"] = "OBO SharePoint Demo";
}

<div class="text-center py-5">
    <h1 class="display-4 mb-4">OBO Graph SharePoint Demo</h1>
    <p class="lead text-muted mb-4">
        Demonstração do fluxo On-Behalf-Of (OBO) com Microsoft Entra ID para acessar documentos do SharePoint via Microsoft Graph.
    </p>

    @if (User.Identity?.IsAuthenticated != true)
    {
        <div class="card mx-auto" style="max-width: 480px;">
            <div class="card-body">
                <h5 class="card-title">Autenticação necessária</h5>
                <p class="card-text">
                    Clique no botão abaixo para entrar com sua conta Microsoft e ver os documentos do SharePoint.
                </p>
                <a asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignIn"
                   class="btn btn-primary btn-lg">
                    🔐 Entrar
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card mx-auto" style="max-width: 480px;">
            <div class="card-body">
                <h5 class="card-title">Bem-vindo, @User.Identity?.Name</h5>
                <p class="card-text">Você está autenticado. Acesse os documentos do SharePoint.</p>
                <a asp-page="/Documents" class="btn btn-success btn-lg">
                    📂 Ver Documentos
                </a>
            </div>
        </div>
    }
</div>

<div class="row mt-5">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">1. Sign-In</h5>
                <p class="card-text">O usuário faz login com OpenID Connect no navegador.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">2. OBO Exchange</h5>
                <p class="card-text">O middle-tier troca o token do usuário por um token do Graph usando certificado X.509.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">3. Graph API</h5>
                <p class="card-text">O Graph retorna os documentos do SharePoint que o usuário autenticado pode acessar.</p>
            </div>
        </div>
    </div>
</div>
