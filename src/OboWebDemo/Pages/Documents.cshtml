@page
@model DocumentsModel
@* Copyright (c) 2026 Ednei Monteiro. Licensed under the MIT License. See LICENSE and DISCLAIMER.md. *@
@{
    ViewData["Title"] = "Documentos SharePoint";
}

<h2 class="mb-4">📂 Documentos do SharePoint</h2>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">
        <strong>Erro:</strong> @Model.ErrorMessage
    </div>
}
else if (Model.Result is not null)
{
    var result = Model.Result;

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card border-primary">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">Usuário autenticado</h6>
                    <p class="card-text fw-bold">@User.Identity?.Name</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-primary">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">Site resolvido</h6>
                    <p class="card-text fw-bold">@result.SiteName</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-primary">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">Biblioteca</h6>
                    <p class="card-text fw-bold">
                        @result.LibraryName
                        @if (!string.IsNullOrWhiteSpace(result.FolderPath))
                        {
                            <span class="text-muted"> / @result.FolderPath</span>
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>

    @if (result.Items.Count == 0)
    {
        <div class="alert alert-info">Nenhum documento encontrado nesta biblioteca.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Tipo</th>
                        <th>Nome</th>
                        <th>Última modificação</th>
                        <th>Tamanho</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in result.Items)
                    {
                        var icon = item.File is not null ? "📄" : item.Folder is not null ? "📁" : "📎";
                        var size = item.Size.HasValue ? FormatSize(item.Size.Value) : "—";
                        var modified = item.LastModifiedDateTime?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "—";
                        <tr>
                            <td>@icon</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.WebUrl))
                                {
                                    <a href="@item.WebUrl" target="_blank" rel="noopener">@(item.Name ?? "(sem nome)")</a>
                                }
                                else
                                {
                                    @(item.Name ?? "(sem nome)")
                                }
                            </td>
                            <td>@modified</td>
                            <td>@size</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="mt-4">
        <div class="card">
            <div class="card-header" role="button" data-bs-toggle="collapse" data-bs-target="#technicalDetails"
                 aria-expanded="false" aria-controls="technicalDetails">
                <h5 class="mb-0">
                    🔍 Technical Details <small class="text-muted">(clique para expandir)</small>
                </h5>
            </div>
            <div id="technicalDetails" class="collapse">
                <div class="card-body">
                    <p class="text-muted mb-3">
                        Cada passo abaixo mostra o que aconteceu internamente durante o fluxo OBO,
                        sem expor tokens ou credenciais.
                    </p>
                    <ol class="list-group list-group-numbered">
                        @foreach (var step in result.Steps)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-start">
                                <div class="ms-2 me-auto">
                                    <div>@step.Description</div>
                                </div>
                                <span class="badge bg-secondary rounded-pill">
                                    @step.Timestamp.ToLocalTime().ToString("HH:mm:ss.fff")
                                </span>
                            </li>
                        }
                    </ol>
                </div>
            </div>
        </div>
    </div>
}

<div class="mt-4">
    <a asp-page="/Index" class="btn btn-outline-secondary">← Voltar</a>
</div>

@functions {
    static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024 * 1024 * 1024) return $"{bytes / (1024.0 * 1024.0):F1} MB";
        return $"{bytes / (1024.0 * 1024.0 * 1024.0):F2} GB";
    }
}
